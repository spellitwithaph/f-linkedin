{
  "manifest_version": 3,
  "name": "f-linkedin",
  "description": "Fixes LinkedIn feed annoyances: Space key hijack, notification hover preview",
  "version": "1.1",
  "content_scripts": [
    {
      "matches": ["https://www.linkedin.com/feed*"],
      "js": ["fix.js", "notifications.js"],
      "run_at": "document_start",
      "world": "MAIN"
    }
  ]
}
